# FlowingFiles - Docker Environment Variables
# Copy this file to .env and configure all variables before running containers.
# Containers will FAIL to start if .env is missing or incomplete.

# === Application Configuration ===
APP_NAME=FlowingFiles

# === Port Configuration ===
WEB_PORT=8080
API_PORT=5000

# === Backend Configuration ===
# Environment: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Production

# === Database Configuration ===
# Npgsql connection string pointing to the existing PostgreSQL instance
DATABASE_URL=Host=<host>;Port=5432;Database=flowingfiles;Username=flowingfiles;Password=change-this-secure-password

# === Gmail Configuration ===
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# === Frontend Build Configuration ===
# API URL that the browser will use to reach the backend
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=FlowingFiles
